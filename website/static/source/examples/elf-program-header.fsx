match Elf.tryParseHeader(ReadOnlySpan<byte>(input)) with
| Ok header ->
    match Contiguous.run (Elf.programHeaderAt header 1) (ReadOnlySpan<byte>(input)) with
    | Ok programHeader ->
        printfn "Class = %A" header.Class
        printfn "Program header type = %u" programHeader.Type
        printfn "Program header flags = %u" programHeader.Flags
    | Error error ->
        printfn "Error = %s @ %A" error.Message error.Position
| Error error ->
